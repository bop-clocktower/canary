{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "(d=$(git rev-parse --show-toplevel 2>/dev/null) && f=$d/.harness/hooks/block-no-verify.js && [ -f \"$f\" ] && node \"$f\") || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "(d=$(git rev-parse --show-toplevel 2>/dev/null) && f=$d/.harness/hooks/protect-config.js && [ -f \"$f\" ] && node \"$f\") || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "(d=$(git rev-parse --show-toplevel 2>/dev/null) && f=$d/.harness/hooks/quality-gate.js && [ -f \"$f\" ] && node \"$f\") || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "(d=$(git rev-parse --show-toplevel 2>/dev/null) && f=$d/.harness/hooks/pre-compact-state.js && [ -f \"$f\" ] && node \"$f\") || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "(d=$(git rev-parse --show-toplevel 2>/dev/null) && f=$d/.harness/hooks/adoption-tracker.js && [ -f \"$f\" ] && node \"$f\") || true"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "(d=$(git rev-parse --show-toplevel 2>/dev/null) && f=$d/.harness/hooks/telemetry-reporter.js && [ -f \"$f\" ] && node \"$f\") || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true
  }
}
