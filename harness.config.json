{
  "version": 1,
  "name": "canary",
  "language": "python",
  "template": {
    "language": "python",
    "version": 1,
    "level": "intermediate"
  },
  "tooling": {
    "packageManager": "pip",
    "linter": "ruff",
    "formatter": "ruff",
    "testRunner": "pytest"
  },
  "layers": [
    {
      "name": "llm",
      "pattern": "agent/llm/**",
      "allowedDependencies": []
    },
    {
      "name": "core",
      "pattern": "agent/core/**",
      "allowedDependencies": [
        "llm"
      ]
    },
    {
      "name": "cli",
      "pattern": "agent/cli.py",
      "allowedDependencies": [
        "core",
        "llm"
      ]
    },
    {
      "name": "tests",
      "pattern": "tests/**",
      "allowedDependencies": [
        "core",
        "llm"
      ]
    }
  ],
  "forbiddenImports": [
    {
      "from": "agent/llm/**",
      "disallow": [
        "agent/core/**",
        "agent/cli.py"
      ],
      "message": "LLM layer must remain isolated from business logic and CLI."
    }
  ],
  "agentsMapPath": "./AGENTS.md",
  "docsDir": "./docs",
  "entryPoints": [
    "agent.cli:app"
  ],
  "entropy": {
    "rootDir": ".",
    "analyze": {
      "drift": {
        "checkApiSignatures": false
      }
    }
  },
  "telemetry": {
    "enabled": true
  },
  "adoption": {
    "enabled": true
  },
  "roadmap": {
    "tracker": {
      "kind": "github",
      "repo": "bop-clocktower/canary",
      "labels": ["harness-managed"],
      "statusMap": {
        "backlog": "open",
        "planned": "open",
        "in-progress": "open",
        "done": "closed",
        "blocked": "open"
      },
      "reverseStatusMap": {
        "closed": "done",
        "open:in-progress": "in-progress",
        "open:blocked": "blocked",
        "open:planned": "planned"
      }
    }
  }
}
