{
  "name": "@canary/engine-ts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript pilot port of the Canary analysis engine (strangler migration).",
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"*.ts\"",
    "test": "vitest run --coverage"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
